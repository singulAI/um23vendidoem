# =============================================================================
# 123Vendido — Frontend environment template
# =============================================================================
# Real values for VITE_SUPABASE_* are auto-managed by Lovable Cloud and are
# already present in .env. Do NOT commit your real .env.

# --- Lovable Cloud (auto-managed; included here for reference) ----------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- External business backend (FastAPI) --------------------------------------
# Base URL of the future FastAPI service. Leave empty while the frontend
# still runs against mock providers.
VITE_API_BASE_URL=https://api.123vendido.com

# Provider toggle: "mock" (default) or "rest" (calls VITE_API_BASE_URL).
# All business modules respect this flag — no UI changes required to swap.
VITE_API_PROVIDER=mock
